# Mobile — environment variable template
# Copy to .env and fill in your values

# Backend port (used in dev auto-detection and as fallback)
EXPO_PUBLIC_API_PORT=8080

# Full base URL used in production builds (non-dev)
# For local dev this is auto-detected from the Expo bundle URL.
# Set to your production server for release builds:
#   EXPO_PUBLIC_API_BASE_URL=http://<your-server-ip>:8080/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
